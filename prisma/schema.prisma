generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SizePreset {
  POKER
  TAROT
  CUSTOM
}

enum TextLayout {
  NONE
  TITLE_BANNER
  TEXT_BOX
}

enum GenStatus {
  PENDING
  DONE
  FAILED
}

model CardSet {
  id            String     @id @default(cuid())
  name          String
  description   String?
  stylePrompt   String
  showNumbers   Boolean    @default(false)
  sizePreset    SizePreset @default(TAROT)
  widthMm       Float      @default(70)
  heightMm      Float      @default(120)
  cards         Card[]
  locations     Location[]
  sharedBacks   CardFace[] @relation("SetSharedBacks")
  defaultBackId String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Location {
  id          String    @id @default(cuid())
  set         CardSet   @relation(fields: [setId], references: [id], onDelete: Cascade)
  setId       String
  name        String
  description String?
  orderIndex  Int       @default(0)
  panorama    CardFace? @relation("LocationPanorama", fields: [panoramaId], references: [id], onDelete: SetNull)
  panoramaId  String?   @unique
  cards       Card[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Card {
  id            String    @id @default(cuid())
  set           CardSet   @relation(fields: [setId], references: [id], onDelete: Cascade)
  setId         String
  location      Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId    String?
  positionLabel String?
  backText      String?
  inPanorama    Boolean   @default(false)
  // Item cards: grouped in the set's flat Items section; their number is drawn
  // as a rendered overlay over the set's default shared back (see lib/overlay).
  isItem        Boolean   @default(false)
  name          String
  number        Int?
  orderIndex    Int       @default(0)
  copies        Int       @default(1)
  front         CardFace  @relation("CardFront", fields: [frontFaceId], references: [id])
  frontFaceId   String    @unique
  back          CardFace? @relation("CardBack", fields: [backFaceId], references: [id])
  backFaceId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CardFace {
  id              String           @id @default(cuid())
  textLayout      TextLayout       @default(TITLE_BANNER)
  title           String?
  bodyText        String?
  imagePrompt     String?
  activeImageId   String?
  variantLabel    String?
  // When true, the position label/back text is drawn as a rendered overlay at
  // preview + PDF time (cheap, style-consistent, reorder-safe) instead of being
  // baked into the image. Used by panorama member backs.
  labelOverlay    Boolean          @default(false)
  basedOnFace     CardFace?        @relation("FaceVariants", fields: [basedOnFaceId], references: [id], onDelete: SetNull)
  basedOnFaceId   String?
  variants        CardFace[]       @relation("FaceVariants")
  images          GeneratedImage[]
  frontOfCard     Card?            @relation("CardFront")
  backOfCards     Card[]           @relation("CardBack")
  panoramaOfLocation Location?     @relation("LocationPanorama")
  sharedBackOfSet CardSet?         @relation("SetSharedBacks", fields: [sharedBackSetId], references: [id], onDelete: Cascade)
  sharedBackSetId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model GeneratedImage {
  id             String    @id @default(cuid())
  face           CardFace  @relation(fields: [faceId], references: [id], onDelete: Cascade)
  faceId         String
  status         GenStatus @default(PENDING)
  resolvedPrompt String
  sourceImageId  String?
  filePath       String?
  widthPx        Int?
  heightPx       Int?
  error          String?
  createdAt      DateTime  @default(now())
}
