generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SizePreset {
  POKER
  TAROT
  IMAGE_2_3
  CUSTOM
}

enum TextLayout {
  NONE
  TITLE_BANNER
  TEXT_BOX
}

enum GenStatus {
  PENDING
  DONE
  FAILED
}

enum ExportStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model CardSet {
  id            String     @id @default(cuid())
  name          String
  description   String?
  stylePrompt   String
  showNumbers   Boolean    @default(false)
  sizePreset    SizePreset @default(TAROT)
  widthMm       Float      @default(70)
  heightMm      Float      @default(120)
  // Print the cards as large as the sheet allows instead of at their nominal
  // size, keeping the aspect and the same cards-per-sheet. See lib/pdf/grid.
  fitToPage     Boolean    @default(false)
  // Print a small running index in the bottom-right corner of every card back,
  // numbered in export order (maps, items, locations). See lib/pdf/export.
  exportIndex   Boolean    @default(false)
  cards         Card[]
  locations     Location[]
  maps          Map[]
  sharedBacks   CardFace[] @relation("SetSharedBacks")
  defaultBackId String?
  // Which shared back item cards use (their number is overlaid on it). Null =
  // fall back to defaultBackId. See lib/faces.resolveBackFaceId.
  itemBackId    String?
  referenceImages ReferenceImage[]
  exportJobs    ExportJob[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

/**
 * One PDF export of a set, run in the background (see lib/pdf/job). The row is
 * the only progress channel: the export runs in-process after the POST has
 * already answered, and the browser polls this row until the file is on disk.
 */
model ExportJob {
  id        String       @id @default(cuid())
  set       CardSet      @relation(fields: [setId], references: [id], onDelete: Cascade)
  setId     String
  status    ExportStatus @default(PENDING)
  /// Coarse stage shown in the UI: "images" | "embed" | "pages" | "saving".
  phase     String       @default("images")
  /// Units finished / total within the current phase — total resets per phase.
  done      Int          @default(0)
  total     Int          @default(0)
  filePath  String?
  bytes     Int?
  error     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([setId, createdAt])
}

/**
 * A picture uploaded by the user (not generated) to seed generation, exactly
 * like referencing another card's front art. Set-scoped and never printed on a
 * card itself. Served by /api/references/[refId].
 */
model ReferenceImage {
  id        String   @id @default(cuid())
  set       CardSet  @relation(fields: [setId], references: [id], onDelete: Cascade)
  setId     String
  name      String
  filePath  String
  widthPx   Int?
  heightPx  Int?
  createdAt DateTime @default(now())
}

model Location {
  id          String    @id @default(cuid())
  set         CardSet   @relation(fields: [setId], references: [id], onDelete: Cascade)
  setId       String
  name        String
  description String?
  orderIndex  Int       @default(0)
  panorama    CardFace? @relation("LocationPanorama", fields: [panoramaId], references: [id], onDelete: SetNull)
  panoramaId  String?   @unique
  cards       Card[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

/**
 * A map is one illustration printed across a 2x2 grid of cards (T.I.M.E Stories
 * style): the master image is sliced into the four cards' *fronts*, and all four
 * share one back design. A 2x2 block of card-aspect tiles has the same aspect as
 * a single card, so the master is generated at the normal card size and each
 * quadrant comes out card-aspect already. See lib/maps + actions/maps.
 */
model Map {
  id         String    @id @default(cuid())
  set        CardSet   @relation(fields: [setId], references: [id], onDelete: Cascade)
  setId      String
  name       String
  orderIndex Int       @default(0)
  // The assembled map reads landscape: the master is generated turned 90° and
  // rotated back before slicing, so the cards themselves stay portrait and the
  // finished grid is turned a quarter turn on the table. See lib/maps.
  landscape  Boolean   @default(true)
  master     CardFace? @relation("MapMaster", fields: [masterId], references: [id], onDelete: SetNull)
  masterId   String?   @unique
  back       CardFace? @relation("MapBack", fields: [backId], references: [id], onDelete: SetNull)
  backId     String?   @unique
  cards      Card[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Card {
  id            String    @id @default(cuid())
  set           CardSet   @relation(fields: [setId], references: [id], onDelete: Cascade)
  setId         String
  location      Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId    String?
  // Map member: its front holds one quadrant of the map's master image.
  map           Map?      @relation(fields: [mapId], references: [id], onDelete: Cascade)
  mapId         String?
  positionLabel String?
  backText      String?
  inPanorama    Boolean   @default(false)
  // Item cards: grouped in the set's flat Items section; their number is drawn
  // as a rendered overlay over the set's default shared back (see lib/overlay).
  isItem        Boolean   @default(false)
  // Card-driven back overlay: draws the position letter + a caption (location
  // name by default) over whatever back the card uses — including the set's
  // shared default back. Used by establishing cards that sit outside the
  // panorama. See lib/overlay.
  labelOverlay  Boolean   @default(false)
  overlayCaption String?
  name          String
  number        Int?
  orderIndex    Int       @default(0)
  copies        Int       @default(1)
  front         CardFace  @relation("CardFront", fields: [frontFaceId], references: [id])
  frontFaceId   String    @unique
  back          CardFace? @relation("CardBack", fields: [backFaceId], references: [id])
  backFaceId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CardFace {
  id              String           @id @default(cuid())
  textLayout      TextLayout       @default(TITLE_BANNER)
  title           String?
  bodyText        String?
  imagePrompt     String?
  activeImageId   String?
  variantLabel    String?
  // When true, the position label/back text is drawn as a rendered overlay at
  // preview + PDF time (cheap, style-consistent, reorder-safe) instead of being
  // baked into the image. Used by panorama member backs.
  labelOverlay    Boolean          @default(false)
  // Placement + look of the rendered overlay drawn over THIS face (label and
  // caption): anchor, offset, size, colour, plate, font. Null = the built-in
  // default. Shape + parsing live in lib/overlaystyle.
  overlayStyle    Json?
  basedOnFace     CardFace?        @relation("FaceVariants", fields: [basedOnFaceId], references: [id], onDelete: SetNull)
  basedOnFaceId   String?
  variants        CardFace[]       @relation("FaceVariants")
  images          GeneratedImage[]
  frontOfCard     Card?            @relation("CardFront")
  backOfCards     Card[]           @relation("CardBack")
  panoramaOfLocation Location?     @relation("LocationPanorama")
  mapMasterOf     Map?             @relation("MapMaster")
  mapBackOf       Map?             @relation("MapBack")
  sharedBackOfSet CardSet?         @relation("SetSharedBacks", fields: [sharedBackSetId], references: [id], onDelete: Cascade)
  sharedBackSetId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model GeneratedImage {
  id             String    @id @default(cuid())
  face           CardFace  @relation(fields: [faceId], references: [id], onDelete: Cascade)
  faceId         String
  status         GenStatus @default(PENDING)
  resolvedPrompt String
  sourceImageId  String?
  filePath       String?
  widthPx        Int?
  heightPx       Int?
  error          String?
  createdAt      DateTime  @default(now())
}
